function classificarPrioridadePreditivaAPS(score) {
    if (score >= 80) return "Crítica";
    if (score >= 70) return "Muito alta";
    if (score >= 40) return "Moderada";
    return "Baixa";
}

function classificarProbabilidadeAPS(score) {
    const p =
        limitarProbabilidadeAPS(score);

    if (p >= 70) return "Alta";
    if (p >= 40) return "Moderada";
    return "Baixa";
}

function limitarProbabilidadeAPS(valor) {
    return Math.max(0, Math.min(95, Math.round(valor)));
}

function contarInteracoesPacienteMotorAPS(p, interacoes) {
    const cpf =
        limparDocumentoMotorAPS(p.cpf || "");

    const cns =
        String(p.cns || "");

    const lista =
        (interacoes || []).filter(i =>
            limparDocumentoMotorAPS(i.paciente_cpf || i.cpf || "") === cpf ||
            String(i.paciente_cns || i.cns || "") === cns
        );

    return {
        total: lista.length,
        naoLocalizado:
            lista.filter(i =>
                normalizarMotorAPS(i.resultado).includes("nao") ||
                normalizarMotorAPS(i.resultado).includes("não") ||
                normalizarMotorAPS(i.resultado).includes("numero invalido") ||
                normalizarMotorAPS(i.resultado).includes("número inválido")
            ).length
    };
}

function identificarPendenciasMotorAPS(p) {
    const pendencias = [];

    if (valorSimMotorAPS(p.has) && (!p.hasPAS || !p.hasPAD)) {
        pendencias.push("HAS sem PA");
    }

    if (valorSimMotorAPS(p.dm) && !p.dmHbA1c) {
        pendencias.push("DM sem HbA1c");
    }

    if (valorSimMotorAPS(p.gestante) && diasDesdeMotorAPS(p.ultimo_atendimento) > 30) {
        pendencias.push("Gestante sem consulta recente");
    }

    if (Number(p.prazo) === 0) {
        pendencias.push("Retorno vencido");
    }

    return pendencias;
}

function valorSimMotorAPS(valor) {
    const v =
        normalizarMotorAPS(valor);

    return (
        valor === true ||
        valor === 1 ||
        v === "sim" ||
        v === "s" ||
        v === "true" ||
        v === "1" ||
        v === "positivo" ||
        v === "presente" ||
        v === "ativo"
    );
}

function normalizarMotorAPS(valor) {
    return String(valor || "")
        .toLowerCase()
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim();
}

function primeiroValorMotorAPS(...valores) {
    for (const v of valores) {
        if (v !== null && v !== undefined && String(v).trim() !== "") {
            return v;
        }
    }

    return null;
}

function diasDesdeMotorAPS(data) {
    if (!data) return 9999;

    const d =
        new Date(data);

    if (Number.isNaN(d.getTime())) {
        return 9999;
    }

    return Math.floor(
        (Date.now() - d.getTime()) /
        (1000 * 60 * 60 * 24)
    );
}

function limparDocumentoMotorAPS(valor) {
    return String(valor || "")
        .replace(/\D/g, "");
}

function escaparMotorAPS(valor) {
    return String(valor || "")
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
}


function renderizarGemeoDigitalMotorAPS(territorios) {
    return `
        <div class="form-section">
            <h3 style="margin-top:0;">🌎 Gêmeo Digital Territorial Inicial</h3>
            <p style="color:var(--text-muted);">
                Simulação simplificada da pressão assistencial territorial baseada em risco preditivo.
